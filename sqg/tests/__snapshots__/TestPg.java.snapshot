        List<Long> bigArr
    ) {}

    private static final PgBulkInsert.PgMapper<
        AllTypesTestRow
    > ALL_TYPES_TEST_MAPPER = PgBulkInsert.PgMapper.forClass(
        AllTypesTestRow.class
    )
        .map(
            "bool_val",
            PgBulkInsert.PostgresTypes.BOOLEAN.from(AllTypesTestRow::boolVal)
        )
        .map(
            "small_val",
            PgBulkInsert.PostgresTypes.INT2.from(AllTypesTestRow::smallVal)
        )
        .map(
            "int_val",
            PgBulkInsert.PostgresTypes.INT4.from(AllTypesTestRow::intVal)
        )
        .map(
            "big_val",
            PgBulkInsert.PostgresTypes.INT8.from(AllTypesTestRow::bigVal)
        )
        .map(
            "real_val",
            PgBulkInsert.PostgresTypes.FLOAT4.from(AllTypesTestRow::realVal)
        )
        .map(
            "double_val",
            PgBulkInsert.PostgresTypes.FLOAT8.from(AllTypesTestRow::doubleVal)
        )
        .map(
            "numeric_val",
            PgBulkInsert.PostgresTypes.NUMERIC.from(AllTypesTestRow::numericVal)
        )
        .map(
            "text_val",
            PgBulkInsert.PostgresTypes.TEXT.from(AllTypesTestRow::textVal)
        )
        .map(
            "varchar_val",
            PgBulkInsert.PostgresTypes.TEXT.from(AllTypesTestRow::varcharVal)
        )
        .map(
            "date_val",
            PgBulkInsert.PostgresTypes.DATE.from(AllTypesTestRow::dateVal)
        )
        .map(
            "ts_val",
            PgBulkInsert.PostgresTypes.TIMESTAMP.from(AllTypesTestRow::tsVal)
        )
        .map(
