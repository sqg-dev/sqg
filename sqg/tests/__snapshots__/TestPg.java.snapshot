    public int insertTask(
        String title,
        TaskStatus status,
        List<String> tags,
        List<Integer> priority_scores
    ) throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "INSERT INTO tasks (title, status, tags, priority_scores) VALUES (?,?::task_status,?,?);"
            )
        ) {
            stmt.setString(1, title);
            stmt.setObject(2, status.getValue());
            stmt.setArray(3, connection.createArrayOf("TEXT", tags.toArray()));
            stmt.setArray(
                4,
                connection.createArrayOf("INT4", priority_scores.toArray())
            );

            return stmt.executeUpdate();
        }
    }

    public record InsertTaskParams(
        String title,
        TaskStatus status,
        List<String> tags,
        List<Integer> priority_scores
    ) {}

    public int[] insertTaskBatch(Iterable<InsertTaskParams> params)
        throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "INSERT INTO tasks (title, status, tags, priority_scores) VALUES (?,?::task_status,?,?);"
            )
        ) {
            for (var row : params) {
                stmt.setString(1, row.title());
                stmt.setObject(2, row.status().getValue());
                stmt.setArray(
                    3,
                    connection.createArrayOf("TEXT", row.tags().toArray())
                );
                stmt.setArray(
                    4,
                    connection.createArrayOf(
                        "INT4",
                        row.priority_scores().toArray()
                    )
                );

                stmt.addBatch();
            }
            return stmt.executeBatch();
        }
    }

    public int insertBigintRecord(
        Long id,
        Short small_id,
        Integer regular_id,
        Long amount,
        String name
    ) throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "INSERT INTO bigint_test (id, small_id, regular_id, amount, name) VALUES (?,?,?,?,?);"
            )
        ) {
            if (id != null) stmt.setLong(1, id);
            else stmt.setNull(1, java.sql.Types.BIGINT);
            if (small_id != null) stmt.setShort(2, small_id);
            else stmt.setNull(2, java.sql.Types.SMALLINT);
            if (regular_id != null) stmt.setInt(3, regular_id);
            else stmt.setNull(3, java.sql.Types.INTEGER);
            if (amount != null) stmt.setLong(4, amount);
            else stmt.setNull(4, java.sql.Types.BIGINT);
            stmt.setString(5, name);

            return stmt.executeUpdate();
        }
    }

