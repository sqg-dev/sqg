    public int[] insertTrickyBatch(Iterable<TrickyEnum> params)
        throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "INSERT INTO tricky_test (val) VALUES (?::tricky_enum);"
            )
        ) {
