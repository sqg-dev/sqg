    public record GetAllTypesRecordResult(
        Integer id,
        Boolean boolVal,
        Short smallVal,
        Integer intVal,
        Long bigVal,
        Float realVal,
        Double doubleVal,
        BigDecimal numericVal,
        String textVal,
        String varcharVal,
        LocalDate dateVal,
        LocalDateTime tsVal,
        OffsetDateTime tstzVal,
        UUID uuidVal,
        String jsonVal,
        List<Integer> intArr,
        List<String> textArr,
        List<Long> bigArr
    ) {}

    public GetAllTypesRecordResult getAllTypesRecord(Integer id)
        throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "SELECT * FROM all_types_test WHERE id =?;"
            )
        ) {
            if (id != null) stmt.setInt(1, id);
            else stmt.setNull(1, java.sql.Types.INTEGER);

            try (var rs = stmt.executeQuery()) {
                return rs.next()
                    ? new GetAllTypesRecordResult(
                          (Integer) rs.getObject(1),
                          (Boolean) rs.getObject(2),
                          rs.getObject(3) != null
                              ? ((Number) rs.getObject(3)).shortValue()
                              : null,
                          (Integer) rs.getObject(4),
                          (Long) rs.getObject(5),
                          (Float) rs.getObject(6),
                          (Double) rs.getObject(7),
                          (BigDecimal) rs.getObject(8),
                          (String) rs.getObject(9),
                          (String) rs.getObject(10),
                          toLocalDate(rs.getObject(11)),
                          toLocalDateTime(rs.getObject(12)),
                          toOffsetDateTime(rs.getObject(13)),
                          (UUID) rs.getObject(14),
                          rs.getObject(15) != null
                              ? rs.getObject(15).toString()
                              : null,
                          arrayToList(
                              (Array) rs.getObject(16),
                              Integer[].class
                          ),
                          arrayToList((Array) rs.getObject(17), String[].class),
                          arrayToList((Array) rs.getObject(18), Long[].class)
                      )
                    : null;
            }
        }
    }

    // ==================== Appenders ====================

    /** Bulk insert rows into bigint_test using PostgreSQL COPY BINARY (via PgBulkInsert). */
    public void bulkInsertBigintTestRow(Iterable<BigintTestRow> rows)
        throws SQLException, IOException {
        BIGINT_TEST_WRITER.saveAll(connection, "bigint_test", rows);
    }

    /** Bulk insert rows into tasks using PostgreSQL COPY BINARY (via PgBulkInsert). */
    public void bulkInsertTasksRow(Iterable<TasksRow> rows)
        throws SQLException, IOException {
        TASKS_WRITER.saveAll(connection, "tasks", rows);
    }

    /** Bulk insert rows into all_types_test using PostgreSQL COPY BINARY (via PgBulkInsert). */
    public void bulkInsertAllTypesTestRow(Iterable<AllTypesTestRow> rows)
        throws SQLException, IOException {
        ALL_TYPES_TEST_WRITER.saveAll(connection, "all_types_test", rows);
    }

    /** Bulk insert rows into identity_test using PostgreSQL COPY BINARY (via PgBulkInsert). */
    public void bulkInsertIdentityTestRow(Iterable<IdentityTestRow> rows)
        throws SQLException, IOException {
        IDENTITY_TEST_WRITER.saveAll(connection, "identity_test", rows);
    }

    /** Row type for bigint_test appender */
    public record BigintTestRow(
        Long id,
        Short smallId,
        Integer regularId,
        Long amount,
        String name
    ) {}

    private static final PgBulkInsert.PgMapper<
        BigintTestRow
    > BIGINT_TEST_MAPPER = PgBulkInsert.PgMapper.forClass(BigintTestRow.class)
        .map("id", PgBulkInsert.PostgresTypes.INT8.from(BigintTestRow::id))
        .map(
            "small_id",
            PgBulkInsert.PostgresTypes.INT2.from(BigintTestRow::smallId)
        )
        .map(
            "regular_id",
            PgBulkInsert.PostgresTypes.INT4.from(BigintTestRow::regularId)
        )
        .map(
            "amount",
            PgBulkInsert.PostgresTypes.INT8.from(BigintTestRow::amount)
        )
        .map("name", PgBulkInsert.PostgresTypes.TEXT.from(BigintTestRow::name));

    private static final PgBulkInsert.PgBulkWriter<
        BigintTestRow
    > BIGINT_TEST_WRITER = new PgBulkInsert.PgBulkWriter<>(BIGINT_TEST_MAPPER);

    /** Row type for tasks appender */
    public record TasksRow(
        String title,
        String status,
        List<String> tags,
        List<Integer> priorityScores
    ) {}

    private static final PgBulkInsert.PgMapper<TasksRow> TASKS_MAPPER =
        PgBulkInsert.PgMapper.forClass(TasksRow.class)
            .map("title", PgBulkInsert.PostgresTypes.TEXT.from(TasksRow::title))
            .map(
                "status",
                PgBulkInsert.PostgresTypes.TEXT.from(TasksRow::status)
            )
            .map(
                "tags",
                PgBulkInsert.PostgresTypes.array(
                    PgBulkInsert.PostgresTypes.TEXT
                ).from(TasksRow::tags)
            )
            .map(
                "priority_scores",
                PgBulkInsert.PostgresTypes.array(
                    PgBulkInsert.PostgresTypes.INT4
                ).from(TasksRow::priorityScores)
            );

    private static final PgBulkInsert.PgBulkWriter<TasksRow> TASKS_WRITER =
        new PgBulkInsert.PgBulkWriter<>(TASKS_MAPPER);

    /** Row type for all_types_test appender */
    public record AllTypesTestRow(
        Boolean boolVal,
