                if (row.id() != null) stmt.setLong(1, row.id());
                else stmt.setNull(1, java.sql.Types.BIGINT);
                if (row.small_id() != null) stmt.setShort(2, row.small_id());
                else stmt.setNull(2, java.sql.Types.SMALLINT);
                if (row.regular_id() != null) stmt.setInt(3, row.regular_id());
                else stmt.setNull(3, java.sql.Types.INTEGER);
                if (row.amount() != null) stmt.setLong(4, row.amount());
                else stmt.setNull(4, java.sql.Types.BIGINT);
                stmt.setString(5, row.name());

                stmt.addBatch();
            }
            return stmt.executeBatch();
        }
    }

    public record GetBigintRecordResult(
        Long id,
        Long serialId,
        Short smallId,
        Integer regularId,
        Long amount,
        String name
    ) {}

    public GetBigintRecordResult getBigintRecord(Long id) throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "SELECT id, serial_id, small_id, regular_id, amount, name FROM bigint_test WHERE id =?;"
            )
        ) {
            if (id != null) stmt.setLong(1, id);
            else stmt.setNull(1, java.sql.Types.BIGINT);

            try (var rs = stmt.executeQuery()) {
                return rs.next()
                    ? new GetBigintRecordResult(
                          (Long) rs.getObject(1),
                          (Long) rs.getObject(2),
                          rs.getObject(3) != null
                              ? ((Number) rs.getObject(3)).shortValue()
                              : null,
                          (Integer) rs.getObject(4),
                          (Long) rs.getObject(5),
                          (String) rs.getObject(6)
                      )
                    : null;
            }
        }
    }

