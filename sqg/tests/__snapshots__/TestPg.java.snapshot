            PgBulkInsert.PostgresTypes.TIMESTAMPTZ.offsetDateTime(
                AllTypesTestRow::tstzVal
            )
        )
        .map(
            "uuid_val",
            PgBulkInsert.PostgresTypes.UUID.from(AllTypesTestRow::uuidVal)
        )
        .map(
            "json_val",
            PgBulkInsert.PostgresTypes.JSONB.from(AllTypesTestRow::jsonVal)
        )
        .map(
            "int_arr",
            PgBulkInsert.PostgresTypes.array(
                PgBulkInsert.PostgresTypes.INT4
            ).from(AllTypesTestRow::intArr)
        )
        .map(
            "text_arr",
            PgBulkInsert.PostgresTypes.array(
                PgBulkInsert.PostgresTypes.TEXT
            ).from(AllTypesTestRow::textArr)
        )
        .map(
            "big_arr",
            PgBulkInsert.PostgresTypes.array(
                PgBulkInsert.PostgresTypes.INT8
            ).from(AllTypesTestRow::bigArr)
        );

    private static final PgBulkInsert.PgBulkWriter<
        AllTypesTestRow
    > ALL_TYPES_TEST_WRITER = new PgBulkInsert.PgBulkWriter<>(
        ALL_TYPES_TEST_MAPPER
    );

