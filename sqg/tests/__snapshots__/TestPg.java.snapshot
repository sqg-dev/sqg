    public record GetTrickyValuesResult(Integer id, TrickyEnum val) {}

    public List<GetTrickyValuesResult> getTrickyValues() throws SQLException {
        try (
            var stmt = connection.prepareStatement(
                "SELECT id, val FROM tricky_test;"
            )
        ) {
            try (var rs = stmt.executeQuery()) {
                var results = new ArrayList<GetTrickyValuesResult>();
                while (rs.next()) {
                    results.add(
                        new GetTrickyValuesResult(
                            (Integer) rs.getObject(1),
                            TrickyEnum.fromValue((String) rs.getObject(2))
                        )
                    );
                }
                return results;
            }
        }
    }

    public Stream<GetTrickyValuesResult> getTrickyValuesStream()
        throws SQLException {
        var stmt = connection.prepareStatement(
            "SELECT id, val FROM tricky_test;"
        );

        var rs = stmt.executeQuery();
        var iter = new Iterator<GetTrickyValuesResult>() {
            private Boolean hasNext = null;

            public boolean hasNext() {
                if (hasNext == null) {
                    try {
                        hasNext = rs.next();
                    } catch (SQLException e) {
                        throw new RuntimeException(e);
                    }
                }
                return hasNext;
            }

            public GetTrickyValuesResult next() {
                if (!hasNext()) throw new NoSuchElementException();
                hasNext = null;
                try {
                    return new GetTrickyValuesResult(
                        (Integer) rs.getObject(1),
                        TrickyEnum.fromValue((String) rs.getObject(2))
                    );
                } catch (SQLException e) {
                    throw new RuntimeException(e);
                }
            }
        };
        return StreamSupport.stream(
            Spliterators.spliteratorUnknownSize(iter, Spliterator.ORDERED),
            false
        ).onClose(() -> {
            try {
                rs.close();
                stmt.close();
            } catch (SQLException e) {
                throw new RuntimeException(e);
            }
        });
    }

