        return [TestAllTypesRow(bool=row[0], tinyint=row[1], smallint=row[2], int=row[3], bigint=row[4], hugeint=row[5], uhugeint=row[6], utinyint=row[7], usmallint=row[8], uint=row[9], ubigint=row[10], bignum=row[11], date=row[12], time=row[13], timestamp=row[14], timestamp_s=row[15], timestamp_ms=row[16], timestamp_ns=row[17], time_tz=row[18], timestamp_tz=row[19], float=row[20], double=row[21], dec_4_1=row[22], dec_9_4=row[23], dec_18_6=row[24], dec_38_10=row[25], uuid=row[26], interval=row[27], varchar=row[28], blob=row[29], bit=row[30], small_enum=row[31], medium_enum=row[32], large_enum=row[33], int_array=row[34], double_array=row[35], date_array=row[36], timestamp_array=row[37], timestamptz_array=row[38], varchar_array=row[39], nested_int_array=row[40], struct=StructStruct(a=row[41]["a"], b=row[41]["b"]), struct_of_arrays=StructOfArraysStruct(a=row[42]["a"], b=row[42]["b"]), array_of_structs=row[43], map=row[44], union=row[45], fixed_int_array=row[46], fixed_varchar_array=row[47], fixed_nested_int_array=row[48], fixed_nested_varchar_array=row[49], fixed_struct_array=row[50], struct_of_fixed_array=StructOfFixedArrayStruct(a=row[51]["a"], b=row[51]["b"]), fixed_array_of_int_list=row[52], list_of_fixed_int_array=row[53]) for row in rows]

    def test_all_types_raw(self) -> list[tuple[Any, ...]]:
        return self._conn.execute(
            "select * from test_all_types();", []
        ).fetchall()

    def insert_event(self, id: int, name: str, tags: list[str | None]) -> None:
        self._conn.execute(
            "INSERT INTO events (id, name, tags) VALUES ($1,$2,$3);", [id, name, tags]
        )

    def all_events(self) -> list[AllEventsRow]:
        rows = self._conn.execute(
            "select * from events;", []
        ).fetchall()
        return [AllEventsRow(id=row[0], name=row[1], tags=row[2]) for row in rows]

    def all_events_raw(self) -> list[tuple[Any, ...]]:
        return self._conn.execute(
            "select * from events;", []
        ).fetchall()

    def all_log_entries(self) -> list[AllLogEntriesRow]:
        rows = self._conn.execute(
            "select * from log_entries;", []
        ).fetchall()
        return [AllLogEntriesRow(id=row[0], message=row[1], created_at=row[2]) for row in rows]

    def all_log_entries_raw(self) -> list[tuple[Any, ...]]:
        return self._conn.execute(
            "select * from log_entries;", []
        ).fetchall()

    def insert_task(self, id: int, title: str, priority: str) -> None:
        self._conn.execute(
            "INSERT INTO tasks (id, title, priority) VALUES ($1,$2,$3);", [id, title, priority]
        )

    def get_tasks_by_priority(self, priority: str) -> list[GetTasksByPriorityRow]:
        rows = self._conn.execute(
            "SELECT id, title, priority FROM tasks WHERE priority =$1;", [priority]
        ).fetchall()
        return [GetTasksByPriorityRow(id=row[0], title=row[1], priority=row[2]) for row in rows]

    def get_tasks_by_priority_raw(self, priority: str) -> list[tuple[Any, ...]]:
        return self._conn.execute(
            "SELECT id, title, priority FROM tasks WHERE priority =$1;", [priority]
        ).fetchall()

    def get_all_tasks(self) -> list[GetAllTasksRow]:
        rows = self._conn.execute(
            "SELECT id, title, priority FROM tasks;", []
        ).fetchall()
        return [GetAllTasksRow(id=row[0], title=row[1], priority=row[2]) for row in rows]

    def get_all_tasks_raw(self) -> list[tuple[Any, ...]]:
        return self._conn.execute(
            "SELECT id, title, priority FROM tasks;", []
        ).fetchall()

    # ==================== Appenders ====================

    def create_users_appender(self) -> UsersAppender:
        return UsersAppender(self._conn.cursor())


    def create_actions_appender(self) -> ActionsAppender:
        return ActionsAppender(self._conn.cursor())


    def create_events_appender(self) -> EventsAppender:
        return EventsAppender(self._conn.cursor())


    def create_log_entries_appender(self) -> LogEntriesAppender:
        return LogEntriesAppender(self._conn.cursor())



@dataclass(frozen=True)
class UsersRow:
    id: int
    name: str
    email: str


class UsersAppender:
    def __init__(self, cursor: duckdb.DuckDBPyConnection) -> None:
        self._cursor = cursor

    def append(self, row: UsersRow) -> UsersAppender:
        self._cursor.execute(
            "INSERT INTO users VALUES ($1, $2, $3)",
            [row.id, row.name, row.email],
        )
        return self

    def append_many(self, rows: list[UsersRow]) -> UsersAppender:
        for row in rows:
            self.append(row)
        return self

    def close(self) -> None:
        self._cursor.close()


@dataclass(frozen=True)
class ActionsRow:
    id: int
    action: str
    value: float | None
    user_id: int
    timestamp: int


class ActionsAppender:
    def __init__(self, cursor: duckdb.DuckDBPyConnection) -> None:
        self._cursor = cursor

    def append(self, row: ActionsRow) -> ActionsAppender:
        self._cursor.execute(
            "INSERT INTO actions VALUES ($1, $2, $3, $4, $5)",
            [row.id, row.action, row.value, row.user_id, row.timestamp],
        )
        return self

    def append_many(self, rows: list[ActionsRow]) -> ActionsAppender:
        for row in rows:
            self.append(row)
        return self

    def close(self) -> None:
        self._cursor.close()


