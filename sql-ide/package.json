{
  "name": "sql-ide",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter server dev\" \"pnpm --filter frontend dev\"",
    "dev:test": "concurrently \"pnpm --filter server dev -- --project=$(pwd)/../sqg/tests/test-duckdb.yaml\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter frontend build",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:server": "pnpm --filter server dev"
  },
  "dependencies": {
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
